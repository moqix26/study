# 安装到 /etc/shortlink/shortlink.env，属主 root:shortlink，权限 0640。
APP_ENV=production
APP_ADDR=127.0.0.1:8080
PUBLIC_BASE_URL=https://s.example.com
TRUSTED_PROXIES=127.0.0.1
SHUTDOWN_TIMEOUT=15s

# 正式项目再启用；示例程序只检查是否设置，不读取数据。
MYSQL_DSN=shortlink:replace-me@tcp(127.0.0.1:3306)/shortlink?parseTime=true&charset=utf8mb4
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=replace-me
JWT_SECRET=replace-with-at-least-32-random-bytes
